{
  "name": "db-explorer-admin",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "Generic database explorer admin dashboard (Electron + React) that connects directly to any PostgreSQL.",
  "author": "Harpalsinh Jadav",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,green \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev:web": "vite",
    "build": "vite build",
    "build:web": "cross-env BUILD_TARGET=web vite build",
    "start": "electron .",
    "preview": "vite preview",
    "lint": "eslint .",
    "dist:mac": "npm run build && electron-builder --mac dmg",
    "dist:mac:universal": "npm run build && electron-builder --mac dmg --universal"
  },
  "build": {
    "appId": "com.dbexplorer.app",
    "productName": "DB Explorer",
    "afterPack": "build/after-pack.cjs",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": "arm64"
        }
      ],
      "identity": null
    },
    "dmg": {
      "title": "${productName}"
    }
  },
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@mui/icons-material": "^6.1.6",
    "@mui/material": "^6.1.6",
    "ag-grid-community": "^32.3.3",
    "ag-grid-react": "^32.3.3",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.14.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  }
}
